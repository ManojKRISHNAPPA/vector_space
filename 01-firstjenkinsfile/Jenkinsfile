pipeline {
    agent any

    environment {
        APP_DIR = "01-firstjenkinsfile"
        VENV = "venv"
    }

    stages {

        stage('Checkout Code') {
            steps {
                checkout scm
            }
        }

        stage('Setup Python Virtual Environment') {
            steps {
                sh '''
                    echo "Creating Python Virtual Environment"

                    cd $APP_DIR

                    # install venv support if missing
                    python3 -m venv $VENV

                    . $VENV/bin/activate

                    pip install --upgrade pip
                    pip install psutil
                    pip install flask psutil
                    echo "Installed packages:"
                    pip list
                '''
            }
        }

        stage('System Info Stage') {
            steps {
                sh '''
                    echo "===== System Information ====="
                    date
                    whoami
                    free -h
                    uname -a
                '''
            }
        }

        stage('Generate Jenkins Monitoring Dashboard') {
            steps {
                sh '''
                    cd $APP_DIR

                    . $VENV/bin/activate

                    echo "Running Monitoring Script..."
                    python3 test.py

                    echo "Files Generated:"
                    ls -lah
                '''
            }
        }

        stage('Validate Dashboard') {
            steps {
                sh '''
                    echo "Validating generated dashboard..."

                    test -f $APP_DIR/status_report.html
                    test -f $APP_DIR/status_history.json

                    echo "Dashboard validation SUCCESS"
                '''
            }
        }

        stage('Publish Status Report') {
            steps {
                archiveArtifacts artifacts: '01-firstjenkinsfile/status_report.html,01-firstjenkinsfile/status_history.json',
                                 fingerprint: true
            }
        }
    }

    post {
        success {
            echo "✅ Jenkins Live Monitoring Dashboard Generated Successfully"
        }

        failure {
            echo "❌ Pipeline Failed — Check Logs"
        }

        always {
            cleanWs()
        }
    }
}
